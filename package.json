{
  "name": "WorkStamp_SF",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "lint": "set ESLINT_USE_FLAT_CONFIG=false&& eslint .",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "guide:validate-used-in": "node scripts/validate-guide-used-in.mjs",
    "quality:guide-docs": "node scripts/check-guide-doc-drift.mjs",
    "quality:onboarding-docs": "node scripts/check-onboarding-doc-drift.mjs",
    "perf:lhci": "lhci autorun --config=./lighthouserc.json",
    "perf:lhci:collect": "lhci collect --config=./lighthouserc.json",
    "perf:check-budgets": "node scripts/check-perf-budgets.mjs",
    "perf:ci": "npm run build && npm run perf:lhci && npm run perf:check-budgets",
    "quality:ci": "npm run lint && npm run guide:validate-used-in && npm run quality:guide-docs && npm run quality:onboarding-docs && npm run perf:ci",
    "postinstall": "nuxt prepare",
    "build:icons": "node app/icons/build-icons.js"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^10.2.3",
    "lottie-web": "^5.13.0",
    "nuxt": "^4.3.0",
    "vue": "^3.5.27",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@netlify/nuxt": "^0.2.34",
    "@nuxt/eslint": "^1.13.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^0.13.2",
    "@pinia/nuxt": "^0.11.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "sass": "^1.97.3"
  }
}
