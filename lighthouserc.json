{
  "ci": {
    "collect": {
      "numberOfRuns": 2,
      "url": [
        "http://127.0.0.1:4173/",
        "http://127.0.0.1:4173/stickers",
        "http://127.0.0.1:4173/stickers/die-cut-sticker",
        "http://127.0.0.1:4173/auth/login",
        "http://127.0.0.1:4173/account"
      ],
      "startServerCommand": "npm run preview -- --host 127.0.0.1 --port 4173",
      "startServerReadyPattern": "Listening",
      "startServerReadyTimeout": 120000,
      "settings": {
        "formFactor": "desktop",
        "throttlingMethod": "provided",
        "screenEmulation": {
          "mobile": false,
          "width": 1350,
          "height": 940,
          "deviceScaleFactor": 1,
          "disabled": false
        }
      }
    },
    "assert": {
      "assertions": {
        "largest-contentful-paint": [
          "error",
          {
            "maxNumericValue": 2500
          }
        ],
        "interaction-to-next-paint": [
          "error",
          {
            "maxNumericValue": 200
          }
        ],
        "cumulative-layout-shift": [
          "error",
          {
            "maxNumericValue": 0.1
          }
        ],
        "categories:performance": [
          "warn",
          {
            "minScore": 0.9
          }
        ],
        "total-byte-weight": [
          "warn",
          {
            "maxNumericValue": 350000
          }
        ],
        "resource-summary:script:size": [
          "warn",
          {
            "maxNumericValue": 170000
          }
        ],
        "resource-summary:stylesheet:size": [
          "warn",
          {
            "maxNumericValue": 70000
          }
        ],
        "resource-summary:image:size": [
          "warn",
          {
            "maxNumericValue": 250000
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
